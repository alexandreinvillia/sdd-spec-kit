@page "/subscriptions"

<PageTitle>Assinaturas</PageTitle>

<h1>Assinaturas RSS</h1>

<div class="mb-3">
    <label for="feedUrl" class="form-label">URL do feed</label>
    <input id="feedUrl" class="form-control" @bind="FeedUrl" placeholder="https://exemplo.com/feed.xml" />
</div>

<button class="btn btn-primary" disabled="@IsSubmitting" @onclick="CreateSubscriptionAsync">Adicionar assinatura</button>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">@ErrorMessage</div>
}

@if (IsLoading)
{
    <p class="mt-3">Carregando assinaturas...</p>
}
else
{
    <ul class="list-group mt-3">
        @if (SubscriptionList.Count == 0)
        {
            <li class="list-group-item">Nenhuma assinatura cadastrada.</li>
        }
        else
        {
            @foreach (var item in SubscriptionList)
            {
                <li class="list-group-item">
                    <strong>@item.FeedUrl</strong>
                    <div class="text-muted small">Criado em @item.CreatedAt.ToLocalTime().ToString("g")</div>
                </li>
            }
        }
    </ul>
}
